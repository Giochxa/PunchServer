        </div>
        <div class="named-line">
            <div class="value">@(string.IsNullOrWhiteSpace(Model.Department) ? "-" : Model.Department)</div>
            <span class="line"></span>
            <div class="label">სტრუქტურული ერთეული</div>
        </div>
        <div class="bottom-row">
            <div class="id-box">
                <div class="label">საიდენტიფიკაციო<br />კოდი</div>
                <div class="value">@Model.IdentificationCode</div>
            </div>
            <div></div>
            <table class="right-date-grid">
                <colgroup>
                    <col class="date-col" />
                    <col />
                    <col />
                </colgroup>
                <tr>
                    <td rowspan="2">შედგენის<br />თარიღი</td>
                    <td colspan="2">საანგარიშო პერიოდი</td>
                </tr>
                <tr>
                    <td>-დან</td>
                    <td>-მდე</td>
                </tr>
                <tr>
                    <td class="date-value">@Model.FormDate.ToString("dd.MM.yyyy")</td>
                    <td class="period-value">@Model.PeriodStart.ToString("dd.MM.yyyy")</td>
                    <td class="period-value">@Model.PeriodEnd.ToString("dd.MM.yyyy")</td>
                </tr>
            </table>
        </div>
    </div>

    <table class="t12">
        <colgroup>
            <col class="c1" />
            <col class="c2" />
            <col class="c3" />
            @for (int i = 1; i <= 15; i++) { <col class="day" /> }
            <col class="sum" />
            @for (int i = 16; i <= 31; i++) { <col class="day" /> }
            <col class="sum" />
