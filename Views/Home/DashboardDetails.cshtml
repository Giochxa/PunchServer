@model PunchServerMVC.Models.ViewModels.DashboardDetailViewModel

@{
    ViewData["Title"] = Model.Title;
    var hasActions = Model.Rows.Any(r => !string.IsNullOrWhiteSpace(r.ActionUrl));
    var selectedMonthStart = Model.Month >= 1 && Model.Month <= 12 && Model.Year >= 1
        ? new DateTime(Model.Year, Model.Month, 1)
        : DateTime.Today;
    var selectedMonthEnd = new DateTime(selectedMonthStart.Year, selectedMonthStart.Month, DateTime.DaysInMonth(selectedMonthStart.Year, selectedMonthStart.Month));
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">@Model.Title</h2>
        <div class="text-muted">@Model.Subtitle</div>
    </div>
    <div class="text-end">
        <div class="small text-muted">Count</div>
        <div class="fs-3 fw-bold @(Model.IsError && Model.Count > 0 ? "text-danger" : "text-dark")">@Model.Count</div>
    </div>
</div>

<div class="mb-3 d-flex justify-content-between align-items-center">
    <a asp-action="Dashboard"
       asp-route-month="@Model.Month"
       asp-route-year="@Model.Year"
       class="btn btn-outline-secondary">Back to Dashboard</a>
    @if (string.Equals(Model.WidgetKey, "extra-punches", StringComparison.OrdinalIgnoreCase))
    {
        <a asp-action="Calendar"
           asp-route-month="@Model.Month"
           asp-route-year="@Model.Year"
           asp-route-showExtraPunchesOnly="true"
           class="btn btn-outline-primary">Calendar</a>
    }
    else if (string.Equals(Model.WidgetKey, "missing-in", StringComparison.OrdinalIgnoreCase))
    {
        <a asp-action="Calendar"
           asp-route-month="@Model.Month"
           asp-route-year="@Model.Year"
           asp-route-showMissing="true"
           asp-route-missingFrom="@selectedMonthStart.ToString("yyyy-MM-dd")"
           asp-route-missingTo="@selectedMonthEnd.ToString("yyyy-MM-dd")"
           asp-route-includeMissingIn="true"
           asp-route-includeMissingOut="false"
           class="btn btn-outline-primary">Calendar</a>
    }
    else if (string.Equals(Model.WidgetKey, "missing-out", StringComparison.OrdinalIgnoreCase))
    {
        <a asp-action="Calendar"
           asp-route-month="@Model.Month"
           asp-route-year="@Model.Year"
           asp-route-showMissing="true"
           asp-route-missingFrom="@selectedMonthStart.ToString("yyyy-MM-dd")"
           asp-route-missingTo="@selectedMonthEnd.ToString("yyyy-MM-dd")"
           asp-route-includeMissingIn="false"
           asp-route-includeMissingOut="true"
           class="btn btn-outline-primary">Calendar</a>
    }
    else if (string.Equals(Model.WidgetKey, "wrong-types", StringComparison.OrdinalIgnoreCase))
    {
        <a asp-action="Calendar"
           asp-route-month="@Model.Month"
           asp-route-year="@Model.Year"
           asp-route-showPunchTypeSuggestions="true"
           asp-route-missingFrom="@selectedMonthStart.ToString("yyyy-MM-dd")"
           asp-route-missingTo="@selectedMonthEnd.ToString("yyyy-MM-dd")"
           class="btn btn-outline-primary">Calendar</a>
    }
    else if (string.Equals(Model.WidgetKey, "auto-punch-out", StringComparison.OrdinalIgnoreCase))
    {
        <a asp-action="PunchLog"
           asp-route-from="@(Model.FilterFrom?.ToString("yyyy-MM-dd"))"
           asp-route-to="@(Model.FilterTo?.ToString("yyyy-MM-dd"))"
           asp-route-punchCondition="autoB"
           class="btn btn-outline-primary">Punch Log</a>
    }
    else if (string.Equals(Model.WidgetKey, "active-employees", StringComparison.OrdinalIgnoreCase))
    {
        <a asp-controller="Employees"
           asp-action="Index"
           class="btn btn-outline-primary">Employees</a>
    }
    else if (string.Equals(Model.WidgetKey, "in-vacation", StringComparison.OrdinalIgnoreCase))
    {
        <a asp-controller="Vacations"
           asp-action="Index"
           asp-route-fromDate="@(Model.FilterFrom?.ToString("yyyy-MM-dd"))"
           asp-route-toDate="@(Model.FilterTo?.ToString("yyyy-MM-dd"))"
           class="btn btn-outline-primary">Vacations</a>
    }
</div>

@if (!Model.Rows.Any())
{
    <div class="alert alert-info">No records found for this widget.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle">
            <thead>
                <tr>
                    @foreach (var column in Model.Columns)
                    {
                        <th>@column</th>
                    }
                    @if (hasActions)
                    {
                        <th>Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Rows)
                {
                    <tr>
                        <td>@row.PrimaryText</td>
                        <td>@row.SecondaryText</td>
                        <td>@row.TertiaryText</td>
                        <td>@row.QuaternaryText</td>
                        @if (hasActions)
                        {
                            <td class="text-nowrap">
                                @if (!string.IsNullOrWhiteSpace(row.ActionUrl))
                                {
                                    <a href="@row.ActionUrl" class="btn btn-sm btn-outline-primary">@row.ActionText</a>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
