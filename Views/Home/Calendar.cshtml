@section Scripts {
    <script>
        window.initializeCalendarEmployeeSelect = window.initializeCalendarEmployeeSelect || function () {
            var $emp = $('#employeeIdCalendar');
            if (!$emp.length || typeof $emp.select2 !== 'function') return;

            if ($emp.hasClass('select2-hidden-accessible')) return;

            $emp.select2({
                width: '100%',
                placeholder: 'All Employees',
                allowClear: true,
                minimumResultsForSearch: 0
            });

            $emp.next('.select2-container').css({
                height: 'calc(1.5em + .75rem + 2px)',
                minHeight: 'calc(1.5em + .75rem + 2px)'
            });
            document.getElementById('employeeIdCalendarWrap')?.classList.add('is-select2-ready');

            $emp.off('select2:open.calendarFocus').on('select2:open.calendarFocus', function () {
                setTimeout(function () {
                    var el = document.querySelector('.select2-container--open .select2-search__field');
                    if (el) el.focus();
                }, 0);
            });
        };

        window.initializeCalendarEmployeeSelect();

        const orgFilter = document.getElementById('organisationFilter');
        const deptFilter = document.getElementById('departmentFilter');

        function filterDepartments() {
            const selectedOrg = orgFilter.value;
            const options = deptFilter.options;

            for (let i = 0; i < options.length; i++) {
                const opt = options[i];
                const orgId = opt.getAttribute('data-org');

                if (!opt.value) continue;
                opt.hidden = (!selectedOrg || orgId === selectedOrg) ? false : true;
            }

            const selected = deptFilter.selectedOptions[0];
            if (selected && selected.hidden) {
                deptFilter.value = '';
            }
        }

        orgFilter.addEventListener('change', filterDepartments);
        window.addEventListener('DOMContentLoaded', filterDepartments);

        // Missing punches select all
        const selectAllMissing = document.getElementById('selectAllMissing');
        if (selectAllMissing) {
            selectAllMissing.addEventListener('change', function () {
                const rows = document.querySelectorAll('.missingRow');
                rows.forEach(r => r.checked = selectAllMissing.checked);
            });
        }

        const selectAllPunchTypeSuggestions = document.getElementById('selectAllPunchTypeSuggestions');
        if (selectAllPunchTypeSuggestions) {
            selectAllPunchTypeSuggestions.addEventListener('change', function () {
                const rows = document.querySelectorAll('.punchTypeRow');
                rows.forEach(r => r.checked = selectAllPunchTypeSuggestions.checked);
            });
        }


        const sharedPunchTooltip = document.getElementById('calendarSharedPunchTooltip');
        const sharedPunchTooltipTitle = document.getElementById('calendarSharedPunchTooltipTitle');
        const sharedPunchTooltipImage = document.getElementById('calendarSharedPunchTooltipImage');
        const sharedPunchTooltipNoImage = document.getElementById('calendarSharedPunchTooltipNoImage');
        const sharedPunchTooltipCreated = document.getElementById('calendarSharedPunchTooltipCreated');
        const sharedPunchTooltipNote = document.getElementById('calendarSharedPunchTooltipNote');
        const sharedEmployeeTooltip = document.getElementById('calendarSharedEmployeeTooltip');
        const sharedEmployeeTooltipImage = document.getElementById('calendarSharedEmployeeTooltipImage');
        const sharedVacationTooltip = document.getElementById('calendarSharedVacationTooltip');
        const sharedVacationTooltipNote = document.getElementById('calendarSharedVacationTooltipNote');
        const hideCalendarPunchImages = @hidePunchImages.ToString().ToLowerInvariant();

        function positionSharedTooltip(trigger, tooltip, event) {
            const rect = trigger.getBoundingClientRect();
            tooltip.style.display = 'block';

            const tooltipRect = tooltip.getBoundingClientRect();
            const viewportPadding = 8;
            const mouseOffset = 12;
            const hasMousePoint = event && typeof event.clientX === 'number' && typeof event.clientY === 'number';
            const anchorX = hasMousePoint ? event.clientX : rect.left + (rect.width / 2);
            const anchorY = hasMousePoint ? event.clientY : rect.bottom;
            const maxLeft = window.innerWidth - tooltipRect.width - viewportPadding;
            const maxTop = window.innerHeight - tooltipRect.height - viewportPadding;

            let left = hasMousePoint
                ? anchorX + mouseOffset
                : anchorX - (tooltipRect.width / 2);
            let top = hasMousePoint
                ? anchorY + mouseOffset
                : rect.bottom + 4;

            if (top + tooltipRect.height > window.innerHeight - viewportPadding) {
                top = hasMousePoint
                    ? anchorY - tooltipRect.height - mouseOffset
                    : rect.top - tooltipRect.height - 4;
            }

            left = Math.max(viewportPadding, Math.min(left, maxLeft));
            top = Math.max(viewportPadding, Math.min(top, maxTop));

            tooltip.style.left = `${left}px`;
            tooltip.style.top = `${top}px`;
        }

        function hideSharedTooltip(tooltip) {
            if (tooltip) {
                tooltip.style.display = 'none';
            }
        }

        document.querySelectorAll('.calendar-punch-marker-wrapper').forEach(wrapper => {
            let lastPunchTooltipEvent = null;

            const showPunchTooltip = (event) => {
                lastPunchTooltipEvent = event;
                const title = wrapper.dataset.tooltipTitle || '';
                const titleClass = wrapper.dataset.tooltipTitleClass || '';
                const imageUrl = wrapper.dataset.imageUrl || '';
                const createdText = wrapper.dataset.createdText || '';
                const noteText = wrapper.dataset.noteText || '';

                sharedPunchTooltipTitle.className = `calendar-punch-tooltip-title ${titleClass}`.trim();
                sharedPunchTooltipTitle.textContent = title;
                sharedPunchTooltipCreated.textContent = createdText;

                if (noteText) {
                    sharedPunchTooltipNote.textContent = noteText;
                    sharedPunchTooltipNote.style.display = 'block';
                } else {
                    sharedPunchTooltipNote.textContent = '';
                    sharedPunchTooltipNote.style.display = 'none';
                }

                if (!hideCalendarPunchImages && imageUrl) {
                    if (sharedPunchTooltipImage.getAttribute('src') !== imageUrl) {
                        sharedPunchTooltipImage.onload = () => positionSharedTooltip(wrapper, sharedPunchTooltip, lastPunchTooltipEvent);
                        sharedPunchTooltipImage.setAttribute('src', imageUrl);
                    }

                    sharedPunchTooltipImage.style.display = 'block';
                    sharedPunchTooltipNoImage.style.display = 'none';
                } else {
                    sharedPunchTooltipImage.removeAttribute('src');
                    sharedPunchTooltipImage.style.display = 'none';
                    sharedPunchTooltipNoImage.style.display = hideCalendarPunchImages ? 'none' : 'block';
                }

                positionSharedTooltip(wrapper, sharedPunchTooltip, event);
            };

            wrapper.addEventListener('mouseenter', showPunchTooltip, { passive: true });
            wrapper.addEventListener('mousemove', event => {
                lastPunchTooltipEvent = event;
                if (sharedPunchTooltip.style.display === 'block') {
                    positionSharedTooltip(wrapper, sharedPunchTooltip, event);
                }
            }, { passive: true });
            wrapper.addEventListener('focus', showPunchTooltip, { passive: true });
            wrapper.addEventListener('mouseleave', () => hideSharedTooltip(sharedPunchTooltip), { passive: true });
            wrapper.addEventListener('blur', () => hideSharedTooltip(sharedPunchTooltip), { passive: true });
        });

        document.querySelectorAll('.calendar-employee-tooltip-trigger').forEach(trigger => {
            const showEmployeeTooltip = () => {
                const imageUrl = trigger.dataset.imageUrl || '';

                if (!imageUrl) {
                    sharedEmployeeTooltipImage.removeAttribute('src');
                    sharedEmployeeTooltipImage.style.display = 'none';
                    hideSharedTooltip(sharedEmployeeTooltip);
                    return;
                }

                const showLoadedEmployeeImage = () => {
                    sharedEmployeeTooltipImage.style.display = 'block';
                    positionSharedTooltip(trigger, sharedEmployeeTooltip);
                };

                const hideBrokenEmployeeImage = () => {
                    sharedEmployeeTooltipImage.removeAttribute('src');
                    sharedEmployeeTooltipImage.style.display = 'none';
                    hideSharedTooltip(sharedEmployeeTooltip);
                };

                if (sharedEmployeeTooltipImage.getAttribute('src') !== imageUrl) {
                    sharedEmployeeTooltipImage.style.display = 'none';
                    sharedEmployeeTooltipImage.onload = showLoadedEmployeeImage;
                    sharedEmployeeTooltipImage.onerror = hideBrokenEmployeeImage;
                    sharedEmployeeTooltipImage.setAttribute('src', imageUrl);
                    return;
                }

                if (sharedEmployeeTooltipImage.complete && sharedEmployeeTooltipImage.naturalWidth > 0) {
                    showLoadedEmployeeImage();
                } else {
                    hideBrokenEmployeeImage();
                }
            };

            trigger.addEventListener('mouseenter', showEmployeeTooltip, { passive: true });
            trigger.addEventListener('focus', showEmployeeTooltip, { passive: true });
            trigger.addEventListener('mouseleave', () => {
                sharedEmployeeTooltipImage.removeAttribute('src');
                sharedEmployeeTooltipImage.style.display = 'none';
                hideSharedTooltip(sharedEmployeeTooltip);
            }, { passive: true });
            trigger.addEventListener('blur', () => {
                sharedEmployeeTooltipImage.removeAttribute('src');
                sharedEmployeeTooltipImage.style.display = 'none';
                hideSharedTooltip(sharedEmployeeTooltip);
            }, { passive: true });
        });

        document.querySelectorAll('.calendar-vacation-note-trigger').forEach(trigger => {
            const showVacationTooltip = () => {
                const noteText = trigger.dataset.noteText || '';
                if (!noteText) {
                    hideSharedTooltip(sharedVacationTooltip);
                    return;
                }

                sharedVacationTooltipNote.textContent = noteText;
                positionSharedTooltip(trigger, sharedVacationTooltip);
            };

            trigger.addEventListener('mouseenter', showVacationTooltip, { passive: true });
            trigger.addEventListener('focus', showVacationTooltip, { passive: true });
            trigger.addEventListener('mouseleave', () => hideSharedTooltip(sharedVacationTooltip), { passive: true });
            trigger.addEventListener('blur', () => hideSharedTooltip(sharedVacationTooltip), { passive: true });
        });

        window.addEventListener('scroll', function () {
            hideSharedTooltip(sharedPunchTooltip);
            hideSharedTooltip(sharedEmployeeTooltip);
            hideSharedTooltip(sharedVacationTooltip);
        }, { passive: true });

        window.addEventListener('resize', function () {
            hideSharedTooltip(sharedPunchTooltip);
            hideSharedTooltip(sharedEmployeeTooltip);
            hideSharedTooltip(sharedVacationTooltip);
        }, { passive: true });

        document.querySelectorAll('.calendar-holiday-marker[title]').forEach(marker => {
            const tooltipText = marker.getAttribute('title');
            if (!tooltipText) return;

            const wrapper = document.createElement('span');
            wrapper.className = 'calendar-holiday-marker-wrapper';
            marker.parentNode.insertBefore(wrapper, marker);
            wrapper.appendChild(marker);
            marker.removeAttribute('title');

            const tooltip = document.createElement('span');
            tooltip.className = 'calendar-holiday-tooltip';
            tooltip.textContent = tooltipText;
            wrapper.appendChild(tooltip);
        });

        // Add Punch Modal
        function openAddPunchModal(employeeId, date) {
            document.getElementById('addEmployeeId').value = employeeId;
            document.getElementById('addPunchDate').value = date;
            document.getElementById('addPunchDateDisplay').value = new Date(date).toLocaleDateString();

            var modal = new bootstrap.Modal(document.getElementById('addPunchModal'));
            modal.show();
        }

        function openAddVacationModal(employeeId, date) {
            document.getElementById('addVacationEmployeeId').value = employeeId;
            document.getElementById('addVacationStartDate').value = date;
            document.getElementById('addVacationEndDate').value = date;

            var modal = new bootstrap.Modal(document.getElementById('addVacationModal'));
            modal.show();
        }

        // Edit Punch Modal
        function openEditPunchModal(punchId, date, time, type, note) {
            document.getElementById('editPunchId').value = punchId;
            document.getElementById('editPunchDate').value = date;
            document.getElementById('editPunchDateDisplay').value = new Date(date).toLocaleDateString();
            document.getElementById('editPunchTime').value = time;
            document.getElementById('editPunchType').value = type;
            document.getElementById('editPunchNote').value = note || '';

            var modal = new bootstrap.Modal(document.getElementById('editPunchModal'));
            modal.show();
        }

        // Delete Punch
        function deletePunch(punchId) {
            if (confirm('Are you sure you want to delete this punch?')) {
                document.getElementById('deletePunchId').value = punchId;
                document.getElementById('deletePunchForm').submit();
            }
        }

        function deleteScheduleDay(scheduleId, date) {
            if (confirm('Are you sure you want to delete only the schedule for this selected day?')) {
                document.getElementById('deleteScheduleId').value = scheduleId;
                document.getElementById('deleteScheduleDate').value = date;
                document.getElementById('deleteScheduleDayForm').submit();
            }
        }
    </script>
}
