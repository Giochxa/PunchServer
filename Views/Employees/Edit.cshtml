@model PunchServerMVC.Models.ViewModels.EmployeeFormViewModel

@{
    ViewData["Title"] = "Edit Employee";
    var activeTab = ((ViewBag.ActiveTab as string) ?? "details").ToLowerInvariant();
    var hidePunchImages = (ViewBag.HidePunchImages as bool?) ?? false;
    var hideProfilePictures = (ViewBag.HideProfilePictures as bool?) ?? false;
}

<h2>Edit Employee</h2>

<ul class="nav nav-tabs mb-3" role="tablist">
    <li class="nav-item"><button class="nav-link @(activeTab == "details" ? "active" : "")" data-bs-toggle="tab" data-bs-target="#employee-details" type="button">Details</button></li>
    <li class="nav-item"><button class="nav-link @(activeTab == "punchlog" ? "active" : "")" data-bs-toggle="tab" data-bs-target="#employee-punchlog" type="button">Punch Log</button></li>
</ul>

<div class="tab-content">
    <div class="tab-pane fade @(activeTab == "details" ? "show active" : "")" id="employee-details">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <partial name="_ValidationScriptsPartial" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="Employee.Id" />
            <input type="hidden" asp-for="Employee.PhotoUrl" />

            @if (!hideProfilePictures && !string.IsNullOrWhiteSpace(Model.EffectivePhotoUrl))
            {
                var photoPath = $"/profile_images/{Model.EffectivePhotoUrl}";
                <div class="mb-3">
                    <label class="form-label d-block">Profile Picture</label>
                    <img src="@photoPath"
                         alt="Profile picture"
                         style="width:120px;height:120px;object-fit:cover;border-radius:8px;border:1px solid #dee2e6;" />
                </div>
            }

            @if (!hideProfilePictures)
            {
                <div class="mb-3">
                    <label class="form-label">Change Profile Picture</label>
                    <input type="file" name="profileImage" class="form-control" accept="image/*" />
                </div>
            }

            <div class="mb-3">
                <label asp-for="Employee.FullName">Full Name</label>
                <input asp-for="Employee.FullName" class="form-control" />
                <span asp-validation-for="Employee.FullName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Employee.UniqueId">Unique Id</label>
                <input asp-for="Employee.UniqueId" class="form-control" />
                <span asp-validation-for="Employee.UniqueId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Employee.PersonalId">Personal Id</label>
                <input asp-for="Employee.PersonalId" class="form-control" />
                <span asp-validation-for="Employee.PersonalId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Employee.Gender">Gender</label>
                <select asp-for="Employee.Gender" class="form-select">
                    <option value="">-- Select Gender --</option>
                    <option value="მდედრობითი">მდედრობითი</option>
                    <option value="მამრობითი">მამრობითი</option>
                </select>
                <span asp-validation-for="Employee.Gender" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Employee.BirthDate">Birth Date</label>
                <input asp-for="Employee.BirthDate" type="date" class="form-control" />
                <span asp-validation-for="Employee.BirthDate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Employee.OrganisationId">Organisation</label>
                <select asp-for="Employee.OrganisationId" class="form-select" id="organisationDropdown"
                        asp-items="@(new SelectList(Model.Organisations, "Id", "Name", Model.Employee.OrganisationId))">
                    <option value="">-- Select Organisation --</option>
                </select>
                <span asp-validation-for="Employee.OrganisationId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Employee.DepartmentId">Department</label>
                <select asp-for="Employee.DepartmentId" class="form-select" id="departmentDropdown">
                    <option value="">-- Select Department --</option>
                    @if (Model.Employee.OrganisationId != null)
                    {
                        foreach (var dept in Model.Departments.Where(d => d.OrganisationId == Model.Employee.OrganisationId))
                        {
                            <option value="@dept.Id" selected="@(dept.Id == Model.Employee.DepartmentId)">@dept.Name</option>
                        }
                    }
                </select>
                <span asp-validation-for="Employee.DepartmentId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Employee.EmploymentStartDate">Employment Start Date</label>
                <input asp-for="Employee.EmploymentStartDate" type="date" class="form-control" />
                <span asp-validation-for="Employee.EmploymentStartDate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Employee.EmploymentEndDate">Employment End Date</label>
                <input asp-for="Employee.EmploymentEndDate" type="date" class="form-control" />
                <span asp-validation-for="Employee.EmploymentEndDate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Employee.Position"></label>
                <input asp-for="Employee.Position" class="form-control" />
                <span asp-validation-for="Employee.Position" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Employee.VacationsPerYear" class="form-label">Vacations Per Year</label>
                <input asp-for="Employee.VacationsPerYear" type="number" class="form-control" />
                <span asp-validation-for="Employee.VacationsPerYear" class="text-danger"></span>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="Employee.RemainingVacations" class="form-label">Remaining Vacations</label>
                    <input asp-for="Employee.RemainingVacations" type="number" class="form-control" />
                    <span asp-validation-for="Employee.RemainingVacations" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Employee.RemainingVacationsFrom" class="form-label">Remaining Vacations from</label>
                    <input asp-for="Employee.RemainingVacationsFrom" type="date" class="form-control" />
                    <span asp-validation-for="Employee.RemainingVacationsFrom" class="text-danger"></span>
                </div>
            </div>

            <div class="form-check mb-3">
                <input asp-for="Employee.IsActive" class="form-check-input" />
                <label asp-for="Employee.IsActive" class="form-check-label">Is Active</label>
            </div>

            <div class="form-check mb-3">
                <input asp-for="Employee.DoesNotNeedSchedule" class="form-check-input" />
                <label asp-for="Employee.DoesNotNeedSchedule" class="form-check-label">Does Not Need Schedule</label>
            </div>

            <button type="submit" class="btn btn-success">Save</button>
            <a href="/Employees" class="btn btn-secondary">Cancel</a>
        </form>
    </div>

    <div class="tab-pane fade @(activeTab == "punchlog" ? "show active" : "")" id="employee-punchlog">
        <form method="get" asp-action="Edit" class="row g-2 mb-3">
            <input type="hidden" name="id" value="@Model.Employee.Id" />
            <input type="hidden" name="activeTab" value="punchlog" />
            <div class="col-md-3">
                <label class="form-label">From</label>
                <input type="date" name="from" class="form-control" value="@Model.PunchLog.From.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-3">
                <label class="form-label">To</label>
                <input type="date" name="to" class="form-control" value="@Model.PunchLog.To.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Punch Type</label>
                <select name="punchType" class="form-select">
                    <option value="" selected="@(string.IsNullOrWhiteSpace(Model.PunchLog.PunchType))">All</option>
                    <option value="In" selected="@(Model.PunchLog.PunchType == "In")">In</option>
                    <option value="Out" selected="@(Model.PunchLog.PunchType == "Out")">Out</option>
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-outline-primary me-2">Filter</button>
                <a asp-action="Edit" asp-route-id="@Model.Employee.Id" asp-route-activeTab="punchlog" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>

        <table class="table table-bordered table-sm align-middle">
            <thead>
                <tr>
                    <th>Timestamp</th>
                    <th>Punch Type</th>
                    <th>Created At</th>
                    <th>Manual</th>
                    <th>Note</th>
                    @if (!hidePunchImages)
                    {
                        <th>Image</th>
                    }
                    @if (!hideProfilePictures)
                    {
                        <th>Profile</th>
                    }
                </tr>
            </thead>
            <tbody>
            @foreach (var punch in Model.PunchLog.Punches)
            {
                string manualText =
                    punch.IsAutoPunchOut ? "Auto Ⓑ" :
                    punch.IsManualEdited ? "Edited manually" :
                    punch.IsManualCreated ? "Added manually" :
                    "Auto";

                <tr>
                    <td>@punch.Timestamp.ToString("dd/MM/yyyy HH:mm:ss")</td>
                    <td>@punch.PunchType</td>
                    <td>@punch.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")</td>
                    <td>@manualText</td>
                    <td>@punch.Note</td>
                    @if (!hidePunchImages)
                    {
                        <td>
                            @if (!string.IsNullOrWhiteSpace(punch.ImageUrl))
                            {
                                <img src="/punch_images/@punch.ImageUrl" alt="Punch Image" style="width:100px;height:auto;" onerror="this.style.display='none'" />
                            }
                        </td>
                    }
                    @if (!hideProfilePictures)
                    {
                        <td>
                            @if (!string.IsNullOrWhiteSpace(punch.ImageUrl))
                            {
                                <form asp-action="SetProfileImageFromPunch" method="post" style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="employeeId" value="@Model.Employee.Id" />
                                    <input type="hidden" name="punchId" value="@punch.Id" />
                                    <input type="hidden" name="from" value="@Model.PunchLog.From.ToString("yyyy-MM-dd")" />
                                    <input type="hidden" name="to" value="@Model.PunchLog.To.ToString("yyyy-MM-dd")" />
                                    <input type="hidden" name="punchType" value="@Model.PunchLog.PunchType" />
                                    <input type="hidden" name="activeTab" value="punchlog" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary">Set as Profile</button>
                                </form>
                            }
                        </td>
                    }
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function loadDepartments(orgId, selectedDeptId) {
            const deptDropdown = document.getElementById('departmentDropdown');
            deptDropdown.innerHTML = '<option value="">-- Select Department --</option>';

            if (!orgId) return;

            fetch(`/api/departments/by-organisation/${orgId}`)
                .then(res => res.json())
                .then(data => {
                    data.forEach(dept => {
                        const opt = document.createElement('option');
                        opt.value = dept.id;
                        opt.text = dept.name;
                        if (dept.id == selectedDeptId) opt.selected = true;
                        deptDropdown.appendChild(opt);
                    });
                })
                .catch(err => console.error('Error loading departments:', err));
        }

        const orgDropdown = document.getElementById('organisationDropdown');
        orgDropdown.addEventListener('change', function () {
            loadDepartments(this.value, null);
        });

        window.addEventListener('load', () => {
            const selectedOrgId = orgDropdown.value;
            const selectedDeptId = "@Model.Employee.DepartmentId";
            if (selectedOrgId) {
                loadDepartments(selectedOrgId, selectedDeptId);
            }
        });
    </script>
}
