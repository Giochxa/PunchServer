@model List<PunchServerMVC.Models.Schedule>
@using PunchServerMVC.Models

@{
    ViewData["Title"] = "Schedules";

    var employeeNames = ViewBag.EmployeeNames as Dictionary<int, string>;
    var allEmployees = ViewBag.AllEmployees as List<Employee> ?? new List<Employee>();
    var scheduleTypes = ViewBag.ScheduleTypes as List<string> ?? new List<string>();

    int? selectedEmployeeId = ViewBag.SelectedEmployeeId as int?;
    string selectedScheduleType = ViewBag.SelectedScheduleType as string;

    DateTime? selectedStartDate = ViewBag.SelectedStartDate as DateTime?;
    DateTime? selectedEndDate = ViewBag.SelectedEndDate as DateTime?;
}

<h2>Schedules</h2>

<style>
    .inline-actions {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        white-space: nowrap;
    }
</style>

<div class="mb-3">
    <a class="btn btn-primary" href="/Schedules/Create">Add Schedule</a>
</div>

<form method="get" asp-action="Index" class="row g-2 mb-3">
    <div class="col-auto" style="min-width:320px;">
        <label class="form-label">Employee</label>

        <select id="employeeId" name="employeeId" class="form-select">
            <option value="">-- All employees --</option>
            @foreach (var e in allEmployees)
            {
                var isSelected = selectedEmployeeId.HasValue && selectedEmployeeId.Value == e.Id;
                <option value="@e.Id" selected="@(isSelected ? "selected" : null)">@e.FullName</option>
            }
        </select>
    </div>

    <div class="col-auto" style="min-width:220px;">
        <label class="form-label">Schedule Type</label>
        <select class="form-select" name="scheduleType">
            <option value="">All</option>
            @foreach (var t in scheduleTypes)
            {
                <option value="@t" selected="@(string.Equals(selectedScheduleType, t, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">
                    @t
                </option>
            }
        </select>
    </div>

    <div class="col-auto">
        <label class="form-label">Start Date</label>
        <input type="date" class="form-control" name="startDate"
               value="@(selectedStartDate.HasValue ? selectedStartDate.Value.ToString("yyyy-MM-dd") : "")" />
    </div>

    <div class="col-auto">
        <label class="form-label">End Date</label>
        <input type="date" class="form-control" name="endDate"
               value="@(selectedEndDate.HasValue ? selectedEndDate.Value.ToString("yyyy-MM-dd") : "")" />
    </div>

    <div class="col-auto align-self-end">
        <button type="submit" class="btn btn-primary">Apply</button>
        <a href="/Schedules/Index" class="btn btn-secondary">Clear</a>
    </div>
</form>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Employee</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Days</th>
            <th>Shift Start</th>
            <th>Shift End</th>
            <th>Type</th>
            <th style="width:160px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@(employeeNames != null && employeeNames.TryGetValue(s.EmployeeId, out var name) ? name : "Unknown")</td>
                <td>@s.StartDate.ToString("dd-MM-yyyy")</td>
                <td>@s.EndDate.ToString("dd-MM-yyyy")</td>
                <td>@string.Join(", ", s.Days)</td>
                <td>@s.ShiftStart</td>
                <td>@s.ShiftEnd</td>
                <td>@s.ScheduleType</td>
                <td>
                    <span class="inline-actions">
                        <a class="btn btn-sm btn-warning" href="/Schedules/Edit/@s.Id" title="Edit">✎</a>

                        <form asp-controller="Schedules"
                              asp-action="Delete"
                              method="post"
                              style="display:inline"
                              onsubmit="return confirm('Are you sure you want to delete this schedule?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@s.Id" />
                            <button type="submit" class="btn btn-sm btn-danger" title="Delete">🗑</button>
                        </form>
                    </span>
                </td>
            </tr>
        }
    </tbody>
</table>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />

<style>
    /* Make Select2 match Bootstrap input height */
    .select2-container .select2-selection--single {
        height: calc(1.5em + .75rem + 2px) !important;
        border: 1px solid #ced4da;
        border-radius: .375rem;
    }

    .select2-container--default .select2-selection--single .select2-selection__rendered {
        line-height: calc(1.5em + .75rem) !important;
        padding-left: .75rem;
        padding-right: 2rem;
    }

    .select2-container--default .select2-selection--single .select2-selection__arrow {
        height: calc(1.5em + .75rem + 2px) !important;
        right: .5rem;
    }
    .select2-container .select2-results__options {
        max-height: 400px !important;
    }

    .select2-container--default .select2-results__option {
        padding: 8px 12px;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        $(function () {
            var $emp = $('#employeeId');

            // prevent double init
            if ($emp.hasClass('select2-hidden-accessible')) {
                $emp.select2('destroy');
            }

            $emp.select2({
                width: '100%',
                placeholder: '-- All employees --',
                allowClear: true,

                // ✅ ALWAYS show the typing/search input
                minimumResultsForSearch: 0
            });

            // OPTIONAL: focus the search input immediately when opening
            $emp.on('select2:open', function () {
                setTimeout(function () {
                    var el = document.querySelector('.select2-container--open .select2-search__field');
                    if (el) el.focus();
                }, 0);
            });
        });
    </script>
}
