@model PunchServerMVC.Models.Schedule
@{
    ViewData["Title"] = "Create Schedule";
    var employees = ViewBag.Employees as IEnumerable<PunchServerMVC.Models.Employee>;
    var templates = ViewBag.Templates as IEnumerable<PunchServerMVC.Models.ScheduleTemplate>;
    var departments = ViewBag.Departments as IEnumerable<PunchServerMVC.Models.Department>;

    var selectedDays = Model?.Days ?? new List<DayOfWeek>();

    var selectedEmployeeIds = new HashSet<int>();
    var preselectedIds = ViewBag.PreselectedEmployeeIds as List<int> ?? new List<int>();
    foreach (var pid in preselectedIds)
        selectedEmployeeIds.Add(pid);

    if (Context?.Request?.Method?.Equals("POST", StringComparison.OrdinalIgnoreCase) == true)
    {
        foreach (var idStr in (Context.Request.Form["EmployeeIds"]))
        {
            if (int.TryParse(idStr, out var id))
                selectedEmployeeIds.Add(id);
        }
    }

}

<h2>Create Schedule</h2>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="returnToCalendar" value="@((bool?)ViewBag.ReturnToCalendar == true ? "true" : "false")" />
    <input type="hidden" name="calendarMonth" value="@ViewBag.CalendarMonth" />
    <input type="hidden" name="calendarYear" value="@ViewBag.CalendarYear" />
    <input type="hidden" name="calendarEmployeeId" value="@ViewBag.CalendarEmployeeId" />
    <input type="hidden" name="calendarOrganisationId" value="@ViewBag.CalendarOrganisationId" />
    <input type="hidden" name="calendarDepartmentId" value="@ViewBag.CalendarDepartmentId" />

    <div class="mb-3">
        <label>Department</label>
        <select class="form-control" id="departmentSelect">
            <option value="">-- All Departments --</option>
            @if (departments != null)
            {
                foreach (var d in departments)
                {
                    <option value="@d.Id">@d.Name</option>
                }
            }
        </select>
        <small class="text-muted d-block mt-1">This filters the employee list (active employees only).</small>
    </div>

    <div class="mb-3">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <label class="mb-0">Employees</label>
            <div class="d-flex align-items-center gap-2">
                <button type="button" id="btnSelectAll" class="btn btn-outline-success btn-sm">Select all</button>
                <button type="button" id="btnClearAll" class="btn btn-outline-secondary btn-sm">Clear all</button>
                <span class="badge bg-primary" id="selectedCount">0 selected</span>
            </div>
        </div>

        <select class="form-control" id="employeeSelect" name="EmployeeIds" multiple="multiple" required>
            @if (employees != null)
            {
                foreach (var e in employees)
                {
                    var lastScheduleDate = ViewBag.EmployeeLastSchedules?.ContainsKey(e.Id) == true
                        ? ((DateTime)ViewBag.EmployeeLastSchedules[e.Id]).AddDays(1).ToString("yyyy-MM-dd")
                        : e.EmploymentStartDate?.ToString("yyyy-MM-dd");

                    <option value="@e.Id"
                            data-last-schedule="@lastScheduleDate"
                            data-start="@e.EmploymentStartDate?.ToString("yyyy-MM-dd")"
                            data-dept="@e.DepartmentId"
                            selected="@(selectedEmployeeIds.Contains(e.Id) ? "selected" : null)">
                        @e.FullName
                    </option>
                }
            }
        </select>

        <span class="text-danger">@Html.ValidationMessage("EmployeeIds")</span>
        <small class="text-muted d-block mt-1">
            Tip: if only 1 employee is selected, Start Date auto-fills from their last schedule and End Date (current week's Sunday day).
            If multiple employees are selected and Start Date is empty, Start Date is auto-calculated per employee on save.
        </small>
    </div>

    <div class="mb-3">
        <label asp-for="StartDate"></label>
        <input asp-for="StartDate"
               type="date"
               class="form-control"
               id="startDate"
               data-preserve-start-date="@(((bool?)ViewBag.PreserveStartDate == true).ToString().ToLowerInvariant())" />
        <span asp-validation-for="StartDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EndDate"></label>
        <input asp-for="EndDate" type="date" class="form-control" id="endDate" />
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Template (optional)</label>
        <select id="templateSelect" asp-for="ScheduleTemplateId" class="form-control">
            <option value="">-- Select Template --</option>
            @if (templates != null)
            {
                foreach (var t in templates)
                {
                    <option value="@t.Id"
                            data-start="@t.ShiftStart.ToString("hh\\:mm")"
                            data-end="@t.ShiftEnd.ToString("hh\\:mm")"
                            data-type="@t.Type"
                            data-break="@t.BreakMinutes"
                            data-days="@string.Join(",", (t.Days ?? new List<DayOfWeek>()))"
                            selected="@(Model.ScheduleTemplateId == t.Id ? "selected" : null)">
                        @t.Name (@t.ShiftStart - @t.ShiftEnd)
                    </option>
                }
            }
        </select>
        <span asp-validation-for="ScheduleTemplateId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Shift Start</label>
        <input asp-for="ShiftStart" type="time" class="form-control" id="shiftStart" />
        <span asp-validation-for="ShiftStart" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Shift End</label>
        <input asp-for="ShiftEnd" type="time" class="form-control" id="shiftEnd" />
        <span asp-validation-for="ShiftEnd" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Break (minutes)</label>
        <input asp-for="BreakMinutes" type="number" class="form-control" id="breakMinutes" />
        <span asp-validation-for="BreakMinutes" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Schedule Type</label>
        <input asp-for="ScheduleType" class="form-control" id="scheduleType" />
        <span asp-validation-for="ScheduleType" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Note"></label>
        <textarea asp-for="Note" class="form-control" rows="2"></textarea>
        <span asp-validation-for="Note" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Days</label><br />
        @foreach (DayOfWeek day in Enum.GetValues(typeof(DayOfWeek)))
        {
            <label class="form-check form-check-inline">
                <input class="form-check-input"
                       type="checkbox"
                       name="Days"
                       value="@day"
                       @(selectedDays.Contains(day) ? "checked" : "") />
                <span class="form-check-label">@day</span>
            </label>
        }
    </div>

    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <button type="submit" class="btn btn-success mt-3">Create</button>
    @if ((bool?)ViewBag.ReturnToCalendar == true)
    {
        <a class="btn btn-secondary mt-3"
           href="@Url.Action("Calendar", "Home", new {
               employeeId = ViewBag.CalendarEmployeeId,
               organisationId = ViewBag.CalendarOrganisationId,
               departmentId = ViewBag.CalendarDepartmentId,
               month = ViewBag.CalendarMonth,
               year = ViewBag.CalendarYear
           })">Cancel</a>
    }
    else
    {
        <a href="/Schedules" class="btn btn-secondary mt-3">Cancel</a>
    }
</form>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />

<style>
