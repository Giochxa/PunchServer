@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        $(function () {
            var $emp = $('#employeeSelect');
            var $dept = $('#departmentSelect');
            var $count = $('#selectedCount');

            if ($emp.hasClass('select2-hidden-accessible')) {
                $emp.select2('destroy');
            }

            $emp.select2({
                width: '100%',
                placeholder: '-- Select Employee(s) --',
                closeOnSelect: false,
                minimumResultsForSearch: 0
            });

            var allOptions = [];
            $emp.find('option').each(function () {
                allOptions.push({
                    value: this.value,
                    text: $(this).text(),
                    lastSchedule: $(this).data('last-schedule'),
                    start: $(this).data('start'),
                    dept: $(this).data('dept')
                });
            });

            $emp.on('select2:open', function () {
                setTimeout(function () {
                    var el = document.querySelector('.select2-container--open .select2-search__field');
                    if (el) el.focus();
                }, 0);
            });

            document.getElementById("templateSelect").addEventListener("change", function () {
                const selected = this.options[this.selectedIndex];
                document.getElementById("shiftStart").value = selected.dataset.start || "";
                document.getElementById("shiftEnd").value = selected.dataset.end || "";
                document.getElementById("scheduleType").value = selected.dataset.type || "";
                document.getElementById("breakMinutes").value = selected.dataset.break || "";

                const days = selected.dataset.days;
                if (days) {
                    const selectedDays = days.split(",").map(x => x.trim());
                    document.querySelectorAll("input[name='Days']").forEach(cb => {
                        cb.checked = selectedDays.includes(cb.value);
                    });
                }
            });

            function getSundayOfWeek(dateString) {
    if (!dateString) return "";

    const d = new Date(dateString + "T00:00:00");
    const day = d.getDay(); // 0=Sunday ... 6=Saturday
    d.setDate(d.getDate() + ((7 - day) % 7));

    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, '0');
    const dd = String(d.getDate()).padStart(2, '0');
    return `${y}-${m}-${dd}`;
}

function refreshEndDateFromStart() {
    const startVal = $('#startDate').val();
    if (!startVal) return;

    const sunday = getSundayOfWeek(startVal);
    if (sunday) {
        $('#endDate').val(sunday);
    }
}

function updateStartDate() {
    const $selected = $('#employeeSelect').find(':selected');
    const count = $selected.length;
    const preserveStartDate = String($('#startDate').data('preserve-start-date')) === 'true';

    if (preserveStartDate && $('#startDate').val()) {
        refreshEndDateFromStart();
        $('#startDate').prop('disabled', false);
        return;
    }

    if (count === 1) {
        const lastSchedule = $selected.data('last-schedule');
        const employmentStart = $selected.data('start');

        if (lastSchedule) {
            $('#startDate').val(lastSchedule);
            refreshEndDateFromStart();
        }
        else if (employmentStart) {
            $('#startDate').val(employmentStart);
            refreshEndDateFromStart();
        }

        $('#startDate').prop('disabled', false);
        return;
    }

    $('#startDate').prop('disabled', false);
}

            $('#employeeSelect').on('change', updateStartDate);
            $('#startDate').on('change', refreshEndDateFromStart);

            function updateSelectedCount() {
                var c = $emp.find(':selected').length;
                $count.text(c + ' selected');
            }

            function applyDepartmentFilter() {
                var deptId = $dept.val();
                var selectedValues = ($emp.val() || []).map(String);

                $emp.empty();
                for (var i = 0; i < allOptions.length; i++) {
                    var o = allOptions[i];
                    if (!deptId || String(o.dept) === String(deptId)) {
                        var opt = new Option(o.text, o.value, false, selectedValues.includes(String(o.value)));
                        $(opt)
                            .attr('data-last-schedule', o.lastSchedule || '')
                            .attr('data-start', o.start || '')
                            .attr('data-dept', o.dept || '');
                        $emp.append(opt);
                    }
                }

                $emp.trigger('change.select2');
                updateStartDate();
                refreshEndDateFromStart();
                updateSelectedCount();
            }

            $dept.on('change', applyDepartmentFilter);

            $('#btnSelectAll').on('click', function () {
                var values = [];
                $emp.find('option').each(function () { values.push(this.value); });
                $emp.val(values).trigger('change');
            });

            $('#btnClearAll').on('click', function () {
                $emp.val([]).trigger('change');
            });

            $emp.on('change', updateSelectedCount);

            updateStartDate();
            updateSelectedCount();
        });
    </script>
}
