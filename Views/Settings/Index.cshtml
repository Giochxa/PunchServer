@model PunchServerMVC.Models.ViewModels.SettingsIndexViewModel

@{
    ViewData["Title"] = "Settings";
    var activeTab = (Model.ActiveTab ?? "holidays").ToLowerInvariant();
}

<h2>Settings</h2>

<style>
    .inline-actions {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        white-space: nowrap;
    }

    .administration-time-input {
        width: 9rem;
    }

    .administration-minutes-input {
        width: 6rem;
    }
</style>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<ul class="nav nav-tabs mb-3">
    <li class="nav-item"><a class="nav-link @(activeTab == "holidays" ? "active" : "")" asp-action="Index" asp-route-activeTab="holidays" asp-route-year="@Model.SelectedYear">Holidays</a></li>
    <li class="nav-item"><a class="nav-link @(activeTab == "vacationtypes" ? "active" : "")" asp-action="Index" asp-route-activeTab="vacationTypes" asp-route-year="@Model.SelectedYear">Vacation Types</a></li>
    <li class="nav-item"><a class="nav-link @(activeTab == "organisations" ? "active" : "")" asp-action="Index" asp-route-activeTab="organisations" asp-route-year="@Model.SelectedYear">Organisations</a></li>
    <li class="nav-item"><a class="nav-link @(activeTab == "departments" ? "active" : "")" asp-action="Index" asp-route-activeTab="departments" asp-route-year="@Model.SelectedYear">Departments</a></li>
    <li class="nav-item"><a class="nav-link @(activeTab == "templates" ? "active" : "")" asp-action="Index" asp-route-activeTab="templates" asp-route-year="@Model.SelectedYear">Templates</a></li>
    <li class="nav-item"><a class="nav-link @(activeTab == "administration" ? "active" : "")" asp-action="Index" asp-route-activeTab="administration" asp-route-year="@Model.SelectedYear">Administration</a></li>
</ul>

@if (activeTab == "holidays")
{
    <div class="d-flex justify-content-between align-items-end mb-3">
        <form method="get" class="d-flex align-items-end gap-2">
            <input type="hidden" name="activeTab" value="holidays" />
            <div>
                <label class="form-label mb-1">Year</label>
                <select name="year" class="form-select">
                    @foreach (var year in Model.AvailableHolidayYears)
                    {
                        <option value="@year" selected="@(year == Model.SelectedYear ? "selected" : null)">@year</option>
                    }
                </select>
            </div>
            <button type="submit" class="btn btn-outline-primary">Filter</button>
        </form>

        <div class="d-flex gap-2">
            <a asp-controller="Holidays" asp-action="Copy" asp-route-year="@Model.SelectedYear" class="btn btn-outline-success">Copy Holidays</a>
            <a asp-controller="Holidays" asp-action="Create" class="btn btn-primary">Add Holiday</a>
        </div>
    </div>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Date</th>
                <th>Name</th>
                <th>Description</th>
                <th>Active</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var holiday in Model.Holidays)
        {
            <tr>
                <td>@holiday.Date.ToString("dd.MM.yyyy")</td>
                <td>@holiday.Name</td>
                <td>@holiday.Description</td>
                <td>@holiday.IsActive</td>
                <td>
                    <span class="inline-actions">
                        <a asp-controller="Holidays" asp-action="Edit" asp-route-id="@holiday.Id" class="btn btn-sm btn-warning" title="Edit">✎</a>
                        <form asp-controller="Holidays" asp-action="Delete" method="post" style="display:inline" onsubmit="return confirm('Are you sure you want to delete this holiday?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@holiday.Id" />
                            <button type="submit" class="btn btn-sm btn-danger" title="Delete">🗑</button>
                        </form>
                    </span>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
else if (activeTab == "vacationtypes")
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <a asp-controller="Vacations" asp-action="CreateType" class="btn btn-primary">Add Vacation Type</a>
    </div>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Abbreviation</th>
                <th>Integration Value</th>
                <th>Count As Used</th>
                <th>Active</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var type in Model.VacationTypes)
        {
            <tr>
                <td>@type.Name</td>
                <td><strong>@type.Abbreviation</strong></td>
                <td>@(string.IsNullOrWhiteSpace(type.IntegrationValue) ? "-" : type.IntegrationValue)</td>
                <td>@(!type.DoesNotCountAsUsedVacations)</td>
                <td>@type.IsActive</td>
                <td>
                    <span class="inline-actions">
                        <a asp-controller="Vacations" asp-action="EditType" asp-route-id="@type.Id" class="btn btn-sm btn-warning" title="Edit">✎</a>
                        <form asp-controller="Vacations" asp-action="DeleteType" method="post" style="display:inline" onsubmit="return confirm('Delete this vacation type?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@type.Id" />
                            <button type="submit" class="btn btn-sm btn-danger" title="Delete">🗑</button>
                        </form>
                    </span>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
else if (activeTab == "organisations")
{
    <a asp-controller="Organisation" asp-action="Create" class="btn btn-primary mb-3">Add Organisation</a>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Number</th>
                <th>Active</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var org in Model.Organisations)
        {
            <tr>
                <td>@org.Name</td>
                <td>@org.OrganisationNumber</td>
                <td>@org.IsActive</td>
                <td>@org.CreatedAt.ToLocalTime().ToString("dd-MM-yyyy")</td>
                <td>
                    <span class="inline-actions">
                        <a asp-controller="Organisation" asp-action="Edit" asp-route-id="@org.Id" class="btn btn-sm btn-warning" title="Edit">✎</a>
                        <form asp-controller="Organisation" asp-action="Delete" method="post" style="display:inline" onsubmit="return confirm('Are you sure you want to delete this organisation?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@org.Id" />
                            <button type="submit" class="btn btn-sm btn-danger" title="Delete">🗑</button>
                        </form>
                    </span>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
else if (activeTab == "departments")
{
    <a asp-controller="Department" asp-action="Create" class="btn btn-primary mb-3">Add Department</a>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Vacations Per Year</th>
                <th>Active</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var dept in Model.Departments)
        {
            <tr>
                <td>@dept.Name</td>
                <td>@dept.Description</td>
                <td>@(dept.VacationsPerYear?.ToString() ?? "-")</td>
                <td>@dept.IsActive</td>
                <td>@dept.CreatedAt.ToLocalTime().ToString("dd-MM-yyyy")</td>
                <td>
                    <span class="inline-actions">
                        <a asp-controller="Department" asp-action="Edit" asp-route-id="@dept.Id" class="btn btn-sm btn-warning" title="Edit">✎</a>
                        <form asp-controller="Department" asp-action="Delete" method="post" style="display:inline" onsubmit="return confirm('Are you sure you want to delete this department?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@dept.Id" />
                            <button type="submit" class="btn btn-sm btn-danger" title="Delete">🗑</button>
                        </form>
                    </span>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
else if (activeTab == "templates")
{
    <a class="btn btn-primary mb-3" asp-controller="ScheduleTemplates" asp-action="Create">Add New Template</a>

    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Start</th>
                <th>End</th>
                <th>Type</th>
                <th>Break (min)</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var t in Model.Templates)
        {
            <tr>
                <td>@t.Name</td>
                <td>@t.ShiftStart.ToString(@"hh\:mm")</td>
                <td>@t.ShiftEnd.ToString(@"hh\:mm")</td>
                <td>@t.Type</td>
                <td>@t.BreakMinutes</td>
                <td>
                    <span class="inline-actions">
                        <a class="btn btn-sm btn-warning" asp-controller="ScheduleTemplates" asp-action="Edit" asp-route-id="@t.Id" title="Edit">✎</a>
                        <form asp-controller="ScheduleTemplates" asp-action="Delete" method="post" style="display:inline" onsubmit="return confirm('Are you sure you want to delete this schedule template?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@t.Id" />
                            <button type="submit" class="btn btn-sm btn-danger" title="Delete">🗑</button>
                        </form>
                    </span>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
else if (activeTab == "administration")
{
    var autoPunchOutTimeClasses = "d-flex align-items-center gap-2" + (Model.AdministrationSettings.AutoPunchOutEnabled ? "" : " d-none");

    <form asp-action="SaveAdministration" method="post" class="card">
        @Html.AntiForgeryToken()
        <div class="card-header">
            <strong>Administration</strong>
        </div>
        <div class="card-body">
            <div class="d-flex flex-wrap align-items-center gap-3">
                <div class="form-check me-2">
                    <input asp-for="AdministrationSettings.AutoPunchOutEnabled" class="form-check-input" id="autoPunchOutEnabled" />
                    <label asp-for="AdministrationSettings.AutoPunchOutEnabled" class="form-check-label">Auto Punch Out</label>
                </div>
                <div id="autoPunchOutTimeWrap" class="@autoPunchOutTimeClasses">
                    <label asp-for="AdministrationSettings.AutoPunchOutTimeCheck" class="col-form-label text-nowrap">Auto Punch Out Time Check</label>
                    <input asp-for="AdministrationSettings.AutoPunchOutTimeCheck" type="time" class="form-control administration-time-input" />
                </div>
                <div>
                    <a asp-action="AutoPunchOutRuns" class="btn btn-outline-primary">View</a>
                </div>
            </div>

            <div class="mt-3 d-flex flex-wrap align-items-center gap-3 small">
                <div><strong>Last Run:</strong> @(Model.LastAutoPunchOutRun?.FinishedAt.ToString("dd.MM.yyyy HH:mm:ss") ?? "Never")</div>
                <div><strong>Status:</strong> @(Model.LastAutoPunchOutRun?.Status ?? "-")</div>
                <div><strong>Message:</strong> @(Model.LastAutoPunchOutRun?.Message ?? "-")</div>
            </div>

            <div class="mt-4 d-flex flex-wrap align-items-center gap-2">
                <label asp-for="AdministrationSettings.DailyBackupTimeCheck" class="col-form-label text-nowrap">Daily database backup time</label>
                <input asp-for="AdministrationSettings.DailyBackupTimeCheck" type="time" class="form-control administration-time-input" />
                <span class="small text-muted">
                    Last backup: @(Model.AdministrationSettings.LastDatabaseBackupRunAt?.ToString("dd.MM.yyyy HH:mm:ss") ?? "Never")
                </span>
            </div>

            <div class="mt-4 d-flex flex-wrap align-items-center gap-4">
                <div class="d-flex align-items-center gap-2">
                    <label asp-for="AdministrationSettings.CalendarPunchGraceMinutes" class="col-form-label text-nowrap">Calendar punch green/red grace (minutes)</label>
                    <input asp-for="AdministrationSettings.CalendarPunchGraceMinutes" type="number" min="1" class="form-control administration-minutes-input" />
                </div>
                <div class="d-flex align-items-center gap-2">
                    <label asp-for="AdministrationSettings.MissingInLookbackMinutes" class="col-form-label text-nowrap">Missing In schedule lookback (minutes)</label>
                    <input asp-for="AdministrationSettings.MissingInLookbackMinutes" type="number" min="1" class="form-control administration-minutes-input" />
                </div>
            </div>

            <div class="mt-4 d-flex flex-wrap align-items-center gap-4">
                <div class="form-check">
                    <input asp-for="AdministrationSettings.HidePunchImages" class="form-check-input" />
                    <label asp-for="AdministrationSettings.HidePunchImages" class="form-check-label">Hide Punch Images</label>
                </div>
                <div class="form-check">
                    <input asp-for="AdministrationSettings.HideProfilePictures" class="form-check-input" />
                    <label asp-for="AdministrationSettings.HideProfilePictures" class="form-check-label">Hide Profile Pictures</label>
                </div>
            </div>

            <div class="mt-4 text-end">
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </div>
    </form>
}

@section Scripts {
    <script>
        (function () {
            const enabled = document.getElementById('autoPunchOutEnabled');
            const timeWrap = document.getElementById('autoPunchOutTimeWrap');
            if (!enabled || !timeWrap) return;

            function syncAutoPunchOutUi() {
                timeWrap.classList.toggle('d-none', !enabled.checked);
            }

            enabled.addEventListener('change', syncAutoPunchOutUi);
            syncAutoPunchOutUi();
        })();
    </script>
}
