@model IEnumerable<PunchServerMVC.Models.Holiday>

@{
    ViewData["Title"] = "Holidays";
    var selectedYear = (int?)ViewBag.SelectedYear ?? DateTime.Today.Year;
    var availableYears = ViewBag.AvailableYears as IEnumerable<int> ?? Enumerable.Empty<int>();
}

<h2>Holidays</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-end mb-3">
    <form method="get" class="d-flex align-items-end gap-2">
        <div>
            <label class="form-label mb-1">Year</label>
            <select name="year" class="form-select">
                @foreach (var year in availableYears)
                {
                    <option value="@year" selected="@(year == selectedYear ? "selected" : null)">@year</option>
                }
            </select>
        </div>
        <button type="submit" class="btn btn-outline-primary">Filter</button>
    </form>

    <a asp-action="Create" class="btn btn-primary">Add Holiday</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Date</th>
            <th>Name</th>
            <th>Description</th>
            <th>Active</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var holiday in Model)
    {
        <tr>
            <td>@holiday.Date.ToString("dd.MM.yyyy")</td>
            <td>@holiday.Name</td>
            <td>@holiday.Description</td>
            <td>@holiday.IsActive</td>
            <td>
                <a asp-action="Edit" asp-route-id="@holiday.Id" class="btn btn-sm btn-warning">Edit</a>
                <form asp-action="Delete"
                      method="post"
                      style="display:inline"
                      onsubmit="return confirm('Are you sure you want to delete this holiday?');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@holiday.Id" />
                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
