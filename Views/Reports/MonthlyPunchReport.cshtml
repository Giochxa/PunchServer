@model PunchServerMVC.Models.ViewModels.MonthlyPunchReportViewModel
@{
    ViewData["Title"] = "Monthly Punch Report";
}


<h2>Monthly Punch Report</h2>

<form method="get">
    <select name="organisationId">
        <option value="">Organisation</option>
        @foreach (var o in Model.Organisations)
        {
            <option value="@o.Id" selected="@(Model.OrganisationId == o.Id)">
                @o.Name
            </option>
        }
    </select>

    <select name="departmentId">
        <option value="">Department</option>
        @foreach (var d in Model.Departments)
        {
            <option value="@d.Id" selected="@(Model.DepartmentId == d.Id)">
                @d.Name
            </option>
        }
    </select>

    <select name="employeeId">
        <option value="">Employee</option>
        @foreach (var e in Model.Employees)
        {
            <option value="@e.Id" selected="@(Model.EmployeeId == e.Id)">
                @e.FullName (@e.PersonalId)
            </option>
        }
    </select>

    <input type="number" name="year" value="@Model.Year" min="2020" max="2050" />
    <input type="number" name="month" value="@Model.Month" min="1" max="12" />
    <button type="submit">Filter</button>
</form>

<hr />

@if (Model.Rows.Any())
{
    var days = DateTime.DaysInMonth(Model.Year, Model.Month);

    <table class="table table-bordered table-striped table-sm">
    <thead>
        <tr>
            <th rowspan="2">Organisation</th>
            <th rowspan="2">Department</th>
            <th rowspan="2">Employee</th>
            <th rowspan="2">PID</th>

            @for (int d = 1; d <= DateTime.DaysInMonth(Model.Year, Model.Month); d++)
            {
                <th colspan="3" class="text-center">@d</th>
            }
        </tr>

        <tr>
            @for (int d = 1; d <= DateTime.DaysInMonth(Model.Year, Model.Month); d++)
            {
                <th>In</th>
                <th>Out</th>
                <th>Diff</th>
            }
        </tr>
    </thead>

    <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td>@row.OrganisationName</td>
                <td>@row.DepartmentName</td>
                <td>@row.EmployeeName</td>
                <td>@row.PersonalId</td>

                @foreach (var day in row.Days)
                {
                    <td>
                        @day.PunchIn?.ToString("dd.MM.yyyy HH:mm:ss") 
                    </td>
                    <td>
                        @day.PunchOut?.ToString("dd.MM.yyyy HH:mm:ss")
                    </td>
                    <td>
                        @(day.DifferenceHours?.ToString("0.##"))
                    </td>
                }
            </tr>
        }
    </tbody>
</table>

}
